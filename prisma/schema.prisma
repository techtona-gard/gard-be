generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model histories {
  history_id     Int             @id @default(autoincrement())
  user_id        String          @db.Uuid
  category       HistoryCategory
  history_date   DateTime        @default(now()) @db.Date
  description    String?
  severity_level String?         @db.VarChar(255)
  doctor_name    String?         @db.VarChar(255)
  doctor_title   String?         @db.VarChar(255)
  gerdq_score    Int?
  created_at     DateTime?       @default(now()) @db.Timestamp(6)
  users          users           @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_history_user")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model roles {
  role_id Int     @id @default(autoincrement())
  name    String  @unique @db.VarChar(255)
  users   users[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  user_id      String       @id @db.Uuid
  role_id      Int?
  height       Int?
  weight       Float?
  birth_date   DateTime?    @db.Date
  emergency_wa String?      @db.VarChar(255)
  status_gerd  String?      @db.VarChar(255)
  created_at   DateTime?    @default(now()) @db.Timestamp(6)
  histories    histories[]
  lifestyles   lifestyles[]
  roles        roles?       @relation(fields: [role_id], references: [role_id], onUpdate: NoAction, map: "fk_user_role")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model medical_guidelines {
  id        String                 @id
  content   String
  metadata  Json?
  embedding Unsupported("vector")?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model lifestyles {
  lifestyle_id Int       @id @default(autoincrement())
  user_id      String    @db.Uuid
  step         Int?
  heartrate    Int?
  sleep        Float?
  recorded_at  DateTime  @default(now()) @db.Timestamp(6)
  users        users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_lifestyle_user")
}

enum HistoryCategory {
  DETEKSI
  KONSULTASI
  KUESIONER
}
