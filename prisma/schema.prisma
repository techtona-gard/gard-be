generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model histories {
  history_id Int       @id @default(autoincrement())
  details    String?
  user_id    String    @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_history_user")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model roles {
  role_id Int     @id @default(autoincrement())
  name    String  @unique @db.VarChar(255)
  users   users[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  user_id       String      @id @db.VarChar(255)
  role_id       Int?
  tinggi_badan  Int?
  berat_badan   Float?
  tanggal_lahir DateTime?   @db.Date
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
  histories     histories[]
  roles         roles?      @relation(fields: [role_id], references: [role_id], onUpdate: NoAction, map: "fk_user_role")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model medical_guidelines {
  id        String                      @id
  content   String
  metadata  Json?
  embedding Unsupported("vector(768)")?
}
